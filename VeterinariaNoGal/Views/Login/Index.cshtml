@{
    ViewData["Title"] = "Iniciar Sesión";
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Agroveterinaria El Nogal — Login</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <style>
        body {
            background: linear-gradient(135deg, #1e4d18, #3a7a2e);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .login-card {
            background: white;
            border-radius: 20px;
            padding: 40px;
            width: 100%;
            max-width: 420px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
        }

        .logo-container {
            text-align: center;
            margin-bottom: 25px;
        }

            .logo-container img {
                height: 120px;
                filter: drop-shadow(0 4px 8px rgba(0,0,0,0.2));
            }

        .login-title {
            text-align: center;
            color: #2d5a27;
            font-weight: bold;
            font-size: 1.4rem;
            margin-bottom: 5px;
        }

        .login-subtitle {
            text-align: center;
            color: #888;
            font-size: 0.9rem;
            margin-bottom: 25px;
        }

        .form-control:focus {
            border-color: #4a7c3f;
            box-shadow: 0 0 0 0.2rem rgba(74,124,63,0.25);
        }

        .btn-login {
            background: linear-gradient(135deg, #2d5a27, #4a7c3f);
            color: white;
            border: none;
            border-radius: 10px;
            padding: 12px;
            font-size: 1rem;
            font-weight: bold;
            width: 100%;
            transition: opacity 0.2s;
        }

            .btn-login:hover {
                opacity: 0.9;
                color: white;
            }

        .form-label {
            color: #2d5a27;
            font-weight: 500;
        }

        .error-msg {
            background: #ffe8e8;
            color: #c0392b;
            border-radius: 8px;
            padding: 10px;
            text-align: center;
            margin-bottom: 15px;
            font-size: 0.9rem;
        }

        .footer-login {
            text-align: center;
            color: #aaa;
            font-size: 0.8rem;
            margin-top: 20px;
        }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="logo-container">
            <img src="/images/logo.png" alt="Logo El Nogal" />
        </div>
        <h2 class="login-title">Agroveterinaria El Nogal</h2>
        <p class="login-subtitle">Ingresá tus credenciales para acceder</p>
        @if (ViewBag.Error != null)
        {
            <div class="error-msg">❌ @ViewBag.Error</div>
        }
        <form method="post" action="/Login/Index">
            <div class="mb-3">
                <label class="form-label">👤 Usuario</label>
                <input type="text" name="email" class="form-control" placeholder="Nombre de usuario" required />
            </div>
            <div class="mb-3">
                <label class="form-label">🔒 Contraseña</label>
                <input type="password" name="password" class="form-control" placeholder="••••••••" required />
            </div>
            <button type="submit" class="btn-login">Ingresar →</button>
        </form>
        <div class="footer-login">
            © 2026 Agroveterinaria El Nogal
        </div>
    </div>
</body>
</html>