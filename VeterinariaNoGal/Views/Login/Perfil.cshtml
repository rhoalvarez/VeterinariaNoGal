@model VeterinariaNoGal.Models.Usuario
@{
    ViewData["Title"] = "Mi Perfil";
    var rol = Context.Session.GetString("rol");
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">

            @if (TempData["Error"] != null)
            {
                <div style="background:#ffe8e8; color:#c0392b; border-radius:10px; padding:12px; margin-bottom:15px; text-align:center;">
                    ❌ @TempData["Error"]
                </div>
            }
            @if (TempData["Exito"] != null)
            {
                <div style="background:#e8f0e0; color:#2d5a27; border-radius:10px; padding:12px; margin-bottom:15px; text-align:center;">
                    ✅ @TempData["Exito"]
                </div>
            }

            <div style="background:white; border-radius:15px; padding:30px; box-shadow:0 4px 15px rgba(0,0,0,0.1); margin-bottom:20px;">
                <div style="text-align:center; margin-bottom:20px;">
                    <div style="font-size:70px;">👤</div>
                    <h3 style="color:#2d5a27; font-weight:bold;">@Model.Nombre</h3>
                    <span style="background:#e8f0e0; color:#2d5a27; padding:4px 12px; border-radius:20px; font-size:13px; font-weight:bold;">@Model.Rol</span>
                </div>
                <hr style="border-color:#e8f0e0;" />

                <h5 style="color:#2d5a27; border-bottom:2px solid #e8f0e0; padding-bottom:10px; margin-bottom:20px;">✏️ Editar Perfil</h5>
                <form method="post" action="/Login/ActualizarPerfil">
                    <input type="hidden" name="idUsuario" value="@Model.IdUsuario" />
                    <div class="mb-3">
                        <label style="color:#2d5a27; font-weight:500;">Nombre de usuario</label>
                        <input type="text" name="nombre" class="form-control" value="@Model.Nombre" required />
                    </div>
                    <button type="submit" class="btn btn-success w-100">💾 Guardar Cambios</button>
                </form>
            </div>

            <div style="background:white; border-radius:15px; padding:30px; box-shadow:0 4px 15px rgba(0,0,0,0.1); margin-bottom:20px;">
                <h5 style="color:#2d5a27; border-bottom:2px solid #e8f0e0; padding-bottom:10px; margin-bottom:20px;">🔒 Cambiar Contraseña</h5>
                <form method="post" action="/Login/CambiarPassword">
                    <input type="hidden" name="idUsuario" value="@Model.IdUsuario" />
                    <div class="mb-3">
                        <label style="color:#2d5a27; font-weight:500;">Contraseña actual</label>
                        <input type="password" name="passwordActual" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label style="color:#2d5a27; font-weight:500;">Nueva contraseña</label>
                        <input type="password" name="passwordNueva" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label style="color:#2d5a27; font-weight:500;">Confirmar nueva contraseña</label>
                        <input type="password" name="passwordConfirmar" class="form-control" required />
                    </div>
                    <button type="submit" class="btn btn-warning w-100">🔑 Cambiar Contraseña</button>
                </form>
            </div>

            @if (rol == "admin")
            {
                <div class="text-center mb-3">
                    <a href="/Login/Usuarios" class="btn btn-primary w-100">👥 Gestionar Usuarios</a>
                </div>
            }

            <div class="text-center">
                <a href="/Home/Index" class="btn btn-secondary">← Volver al inicio</a>
            </div>

        </div>
    </div>
</div>