@model VeterinariaNoGal.Models.Proveedor
@{
    ViewData["Title"] = "Nuevo Proveedor";
}

<div class="container mt-4">
    <h2>Nuevo Proveedor</h2>

    <form method="post" action="/Proveedor/Crear">
        <div class="mb-3">
            <label>Razón Social</label>
            <input type="text" name="RazonSocial" class="form-control" required />
        </div>
        <div class="mb-3">
            <label>DNI / CUIT</label>
            <input type="tel"
                   name="Dni"
                   class="form-control"
                   pattern="[0-9]*"
                   inputmode="numeric"
                   maxlength="11"
                   oninput="this.value = this.value.replace(/[^0-9]/g, '')"
                   placeholder="Solo números, sin guiones" />
            <small class="text-muted">Ej: 20123456789</small>
        </div>
        <div class="mb-3">
            <label>Teléfono</label>
            <input type="tel"
                   name="Telefono"
                   class="form-control"
                   pattern="[0-9]*"
                   inputmode="numeric"
                   oninput="this.value = this.value.replace(/[^0-9]/g, '')"
                   placeholder="Solo números" />
            <small class="text-muted">Ej: 3814123456</small>
        </div>
        <div class="mb-3">
            <label>Email</label>
            <input type="email" name="Email" class="form-control" />
        </div>
        <button type="submit" class="btn btn-success">Guardar</button>
        <a href="/Proveedor/Index" class="btn btn-secondary">Cancelar</a>
    </form>
</div>

