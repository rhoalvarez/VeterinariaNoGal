@model VeterinariaNoGal.Models.Cliente
@{
    ViewData["Title"] = "Editar Cliente";
}

<div class="container mt-4">
    <h2>Editar Cliente</h2>

    <form method="post" action="/Cliente/Editar">
        <input type="hidden" name="Id_Cliente" value="@Model.Id_Cliente" />
        <div style="background: white; border-radius: 15px; padding: 20px; box-shadow: 0 2px 15px rgba(0,0,0,0.1); border-left: 5px solid #2d5a27;">
            <h5 style="color: #2d5a27; margin-bottom: 15px;">👤 Datos del Cliente</h5>
            <div class="row g-3">
                <div class="col-md-6">
                    <label>Nombre completo</label>
                    <input type="text" name="Nombre" value="@Model.Nombre" class="form-control" required />
                </div>
                <div class="col-md-6">
                    <label>Teléfono</label>
                    <input type="tel"
                           name="Telefono"
                           value="@Model.Telefono"
                           class="form-control"
                           required
                           pattern="[0-9]*"
                           inputmode="numeric"
                           oninput="this.value = this.value.replace(/[^0-9]/g, '')" />
                    <small class="text-muted">Solo números, sin espacios ni guiones.</small>
                </div>
            </div>
        </div>
        <div class="mt-3">
            <button type="submit" class="btn btn-success">Guardar cambios</button>
            <a href="/Cliente/Index" class="btn btn-secondary">Cancelar</a>
        </div>
    </form>
</div>