@{
    ViewData["Title"] = "Nueva Venta";
    var clientes = ViewBag.Clientes as List<VeterinariaNoGal.Models.Cliente>;
    var productos = ViewBag.Productos as List<VeterinariaNoGal.Models.Producto>;
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 style="font-weight:800; border-left:5px solid #2d5a27; padding-left:12px;">🛒 Nueva Venta</h2>
        <a href="/Venta/Index" class="btn btn-secondary">← Volver</a>
    </div>

    <div style="background:white; border-radius:15px; padding:20px; box-shadow:0 2px 15px rgba(0,0,0,0.1); margin-bottom:20px;">
        <h5 style="color:#2d5a27; border-bottom:2px solid #4a7c3f; padding-bottom:10px;">📋 Datos de la Venta</h5>
        <div class="row">
            <div class="col-md-4 mb-3">
                <label>Cliente</label>
                <select id="idCliente" class="form-control">
                    @foreach (var c in clientes)
                    {
                        <option value="@c.Id_Cliente">@c.Nombre</option>
                    }
                </select>
            </div>
            <div class="col-md-4 mb-3">
                <label>Forma de Pago</label>
                <select id="formaPago" class="form-control" onchange="mostrarOpciones()">
                    <option value="Efectivo">Efectivo</option>
                    <option value="Tarjeta">Tarjeta</option>
                    <option value="Transferencia">Transferencia</option>
                </select>
            </div>
            <div class="col-md-4 mb-3">
                <label>Observación</label>
                <textarea id="observacion" class="form-control" rows="1"></textarea>
            </div>
        </div>

   
        <div id="divTarjeta" style="display:none; background:#e8f4ff; border-radius:10px; padding:15px; margin-top:10px;">
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label>Interés por uso de tarjeta (%)</label>
                    <input type="number" id="interesTarjeta" class="form-control" value="0" min="0" step="0.5" oninput="actualizarResumen()" />
                </div>
                <div class="col-md-6 mb-3 d-flex align-items-end">
                    <div id="resumenTarjeta" style="font-size:0.95rem; color:#2980b9;"></div>
                </div>
            </div>
        </div>


        <div style="background:#f0f7ee; border-radius:10px; padding:15px; margin-top:10px;">
            <label style="color:#2d5a27; font-weight:600;">¿El cliente puede pagar el total ahora?</label>
            <div class="mt-2">
                <div class="form-check form-check-inline">
                    <input class="form-check-input" type="radio" name="puedePagar" id="siPaga" value="si" checked onchange="toggleCuotas()" />
                    <label class="form-check-label" for="siPaga">✅ Sí, paga ahora</label>
                </div>
                <div class="form-check form-check-inline">
                    <input class="form-check-input" type="radio" name="puedePagar" id="noPaga" value="no" onchange="toggleCuotas()" />
                    <label class="form-check-label" for="noPaga">📋 No, genera Cuenta Corriente</label>
                </div>
            </div>
        </div>

       
        <div id="divCuotas" style="display:none; background:#fff8e1; border-radius:10px; padding:15px; margin-top:10px;">
            <h6 style="color:#e67e22; margin-bottom:12px;">📋 Configurar Cuenta Corriente</h6>
            <div class="row">
                <div class="col-md-3 mb-3">
                    <label>Cantidad de Cuotas</label>
                    <select id="cantCuotas" class="form-control" onchange="calcularCuotas()">
                        <option value="2">2 cuotas</option>
                        <option value="3">3 cuotas</option>
                        <option value="6">6 cuotas</option>
                        <option value="12">12 cuotas</option>
                    </select>
                </div>
                <div class="col-md-3 mb-3">
                    <label>Interés por cuota (%)</label>
                    <input type="number" id="interesCuota" class="form-control" value="0" min="0" max="100" step="0.5" oninput="calcularCuotas()" />
                </div>
                <div class="col-md-3 mb-3">
                    <label>Fecha primera cuota</label>
                    <input type="date" id="fechaPrimeraCuota" class="form-control" oninput="calcularCuotas()" />
                </div>
                <div class="col-md-3 mb-3">
                    <label>Pago de cuotas en</label>
                    <select id="formaPagoCuotas" class="form-control">
                        <option value="Efectivo">Efectivo</option>
                        <option value="Tarjeta">Tarjeta</option>
                    </select>
                </div>
            </div>
            <div id="previewCuotas" style="display:none; overflow-x:auto;">
                <h6 style="color:#2d5a27; margin-bottom:8px;">📋 Detalle de cuotas:</h6>
                <table class="table table-sm table-bordered mb-0" style="min-width:400px;">
                    <thead class="table-dark">
                        <tr>
                            <th>Cuota</th>
                            <th>Vencimiento</th>
                            <th>Monto sin interés</th>
                            <th>Interés</th>
                            <th>Total cuota</th>
                        </tr>
                    </thead>
                    <tbody id="cuotasPreviewBody"></tbody>
                </table>
                <div style="margin-top:10px; padding:10px; background:#e8f0e0; border-radius:8px;">
                    <span style="color:#2d5a27;">Total sin interés: <b>$<span id="totalSinInteres">0.00</span></b></span>
                    &nbsp;|&nbsp;
                    <span style="color:#e74c3c;">Total con interés: <b>$<span id="totalConInteres">0.00</span></b></span>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6">
            <div style="background:white; border-radius:15px; padding:20px; box-shadow:0 2px 15px rgba(0,0,0,0.1); margin-bottom:20px;">
                <ul class="nav nav-tabs mb-3">
                    <li class="nav-item">
                        <a class="nav-link active" id="tabProducto" href="#" onclick="switchTab('producto')">🛍️ Producto</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" id="tabServicio" href="#" onclick="switchTab('servicio')">💉 Servicio</a>
                    </li>
                </ul>
                <div id="panelProducto">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label>Producto</label>
                            <select id="productoSelect" class="form-control">
                                @foreach (var p in productos)
                                {
                                    <option value="@p.IdProductos" data-precio="@p.PMinorista" data-nombre="@p.Nombre" data-stock="@p.Stock">
                                        @p.Nombre — $@p.PMinorista.ToString("N2") (Stock: @p.Stock)
                                    </option>
                                }
                            </select>
                        </div>
                        <div class="col-md-3 mb-3">
                            <label>Cantidad</label>
                            <input type="number" id="cantidad" class="form-control" value="1" min="1" />
                        </div>
                        <div class="col-md-3 d-flex align-items-end mb-3">
                            <button onclick="agregarProducto()" class="btn btn-primary w-100">Agregar</button>
                        </div>
                    </div>
                </div>
                <div id="panelServicio" style="display:none;">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label>Descripción del servicio</label>
                            <input type="text" id="descripcionServicio" class="form-control" placeholder="Ej: Castración, Consulta..." />
                        </div>
                        <div class="col-md-3 mb-3">
                            <label>Precio</label>
                            <input type="number" id="precioServicio" class="form-control" value="0" min="0" step="0.01" />
                        </div>
                        <div class="col-md-3 d-flex align-items-end mb-3">
                            <button onclick="agregarServicio()" class="btn btn-success w-100">Agregar</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div style="background:white; border-radius:15px; padding:20px; box-shadow:0 2px 15px rgba(0,0,0,0.1);">
                <h5 style="color:#2d5a27; border-bottom:2px solid #4a7c3f; padding-bottom:10px;">🛒 Carrito</h5>
                <div style="overflow-x:auto; -webkit-overflow-scrolling:touch;">
                    <table class="table table-sm" style="min-width:350px;">
                        <thead>
                            <tr>
                                <th>Descripción</th>
                                <th>Tipo</th>
                                <th>Cant.</th>
                                <th>Precio</th>
                                <th>Subtotal</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody id="carritoBody"></tbody>
                    </table>
                </div>
                <div style="border-top:2px solid #4a7c3f; padding-top:10px; margin-top:10px;">
                    <h5 style="color:#2d5a27;">Total: $<span id="totalVenta">0.00</span></h5>
                    <div id="resumenPago" style="font-size:0.9rem; color:#555; margin-top:5px;"></div>
                </div>
                <button onclick="finalizarVenta()" class="btn btn-success w-100 mt-3" style="font-size:1.1rem;">
                    ✅ Finalizar Venta
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    let carrito = [];

    document.addEventListener('DOMContentLoaded', () => {
        const hoy = new Date().toISOString().split('T')[0];
        document.getElementById('fechaPrimeraCuota').value = hoy;
        document.getElementById('fechaPrimeraCuota').min = hoy;
    });

    function switchTab(tab) {
        document.getElementById('panelProducto').style.display = tab === 'producto' ? 'block' : 'none';
        document.getElementById('panelServicio').style.display = tab === 'servicio' ? 'block' : 'none';
        document.getElementById('tabProducto').classList.toggle('active', tab === 'producto');
        document.getElementById('tabServicio').classList.toggle('active', tab === 'servicio');
    }

    function mostrarOpciones() {
        const forma = document.getElementById('formaPago').value;
        document.getElementById('divTarjeta').style.display = forma === 'Tarjeta' ? 'block' : 'none';
        actualizarResumen();
    }

    function toggleCuotas() {
        const noPaga = document.getElementById('noPaga').checked;
        document.getElementById('divCuotas').style.display = noPaga ? 'block' : 'none';
        if (noPaga) calcularCuotas();
        actualizarResumen();
    }

    function getTotal() {
        return carrito.reduce((s, i) => s + i.subtotal, 0);
    }

    function actualizarResumen() {
        const total = getTotal();
        const forma = document.getElementById('formaPago').value;
        const noPaga = document.getElementById('noPaga').checked;
        let resumen = '';

        if (forma === 'Tarjeta' && !noPaga) {
            const interes = parseFloat(document.getElementById('interesTarjeta').value) || 0;
            const totalConInteres = total * (1 + interes / 100);
            if (interes > 0) {
                resumen = `Total sin interés: $${total.toFixed(2)} | Con interés tarjeta (${interes}%): <b style="color:#e74c3c;">$${totalConInteres.toFixed(2)}</b>`;
                document.getElementById('resumenTarjeta').innerHTML = `Total a pagar: <b style="color:#e74c3c;">$${totalConInteres.toFixed(2)}</b>`;
            } else {
                document.getElementById('resumenTarjeta').innerHTML = '';
            }
        }

        document.getElementById('resumenPago').innerHTML = resumen;
    }

    function calcularCuotas() {
        const cant = parseInt(document.getElementById('cantCuotas').value);
        const interes = parseFloat(document.getElementById('interesCuota').value) || 0;
        const fechaStr = document.getElementById('fechaPrimeraCuota').value;
        const total = getTotal();
        if (total === 0 || !fechaStr) {
            document.getElementById('previewCuotas').style.display = 'none';
            return;
        }
        const montoCuota = total / cant;
        const montoConInteres = montoCuota * (1 + interes / 100);
        const totalConInteres = montoConInteres * cant;
        const tbody = document.getElementById('cuotasPreviewBody');
        tbody.innerHTML = '';
        for (let i = 0; i < cant; i++) {
            const fecha = new Date(fechaStr + 'T00:00:00');
            fecha.setMonth(fecha.getMonth() + i);
            tbody.innerHTML += `
                <tr>
                    <td style="text-align:center">${i + 1}</td>
                    <td>${fecha.toLocaleDateString('es-AR')}</td>
                    <td>$${montoCuota.toFixed(2)}</td>
                    <td>${interes}%</td>
                    <td><b>$${montoConInteres.toFixed(2)}</b></td>
                </tr>`;
        }
        document.getElementById('totalSinInteres').textContent = total.toFixed(2);
        document.getElementById('totalConInteres').textContent = totalConInteres.toFixed(2);
        document.getElementById('previewCuotas').style.display = 'block';
    }

    function agregarProducto() {
        const select = document.getElementById('productoSelect');
        const option = select.options[select.selectedIndex];
        const cantidad = parseInt(document.getElementById('cantidad').value);
        const stock = parseInt(option.getAttribute('data-stock'));
        if (cantidad > stock) { alert('No hay suficiente stock! Disponible: ' + stock); return; }
        const idProducto = parseInt(select.value);
        const nombre = option.getAttribute('data-nombre');
        const precio = parseFloat(option.getAttribute('data-precio'));
        const subtotal = precio * cantidad;
        const existente = carrito.find(i => i.idProducto === idProducto && i.tipo === 'producto');
        if (existente) {
            existente.cantidad += cantidad;
            existente.subtotal = existente.precio * existente.cantidad;
        } else {
            carrito.push({ idProducto, nombre, cantidad, precio, subtotal, tipo: 'producto' });
        }
        actualizarCarrito();
    }

    function agregarServicio() {
        const descripcion = document.getElementById('descripcionServicio').value.trim();
        const precio = parseFloat(document.getElementById('precioServicio').value) || 0;
        if (!descripcion) { alert('Ingresá una descripción del servicio'); return; }
        if (precio <= 0) { alert('Ingresá un precio válido'); return; }
        carrito.push({ idProducto: null, nombre: descripcion, cantidad: 1, precio, subtotal: precio, tipo: 'servicio' });
        document.getElementById('descripcionServicio').value = '';
        document.getElementById('precioServicio').value = 0;
        actualizarCarrito();
    }

    function eliminarDelCarrito(index) {
        carrito.splice(index, 1);
        actualizarCarrito();
    }

    function actualizarCarrito() {
        const tbody = document.getElementById('carritoBody');
        tbody.innerHTML = '';
        let total = 0;
        carrito.forEach((item, index) => {
            total += item.subtotal;
            tbody.innerHTML += `
                <tr>
                    <td>${item.nombre}</td>
                    <td><span class="badge ${item.tipo === 'servicio' ? 'bg-info' : 'bg-success'}">${item.tipo}</span></td>
                    <td>${item.cantidad}</td>
                    <td>$${item.precio.toFixed(2)}</td>
                    <td>$${item.subtotal.toFixed(2)}</td>
                    <td><button onclick="eliminarDelCarrito(${index})" class="btn btn-danger btn-sm">X</button></td>
                </tr>`;
        });
        document.getElementById('totalVenta').textContent = total.toFixed(2);
        if (document.getElementById('noPaga').checked) calcularCuotas();
        actualizarResumen();
    }

    function finalizarVenta() {
        if (carrito.length === 0) { alert('El carrito está vacío!'); return; }

        const formaPago = document.getElementById('formaPago').value;
        const noPaga = document.getElementById('noPaga').checked;
        const total = getTotal();
        let cantCuotas = 0, interes = 0, fechaPrimeraCuota = null;
        let montoPagado = total, saldoPendiente = 0, totalConInteres = total;
        let formaPagoCuotas = null;

        if (noPaga) {
            // Genera Cuenta Corriente
            cantCuotas = parseInt(document.getElementById('cantCuotas').value);
            interes = parseFloat(document.getElementById('interesCuota').value) || 0;
            fechaPrimeraCuota = document.getElementById('fechaPrimeraCuota').value;
            formaPagoCuotas = document.getElementById('formaPagoCuotas').value;
            const montoCuota = total / cantCuotas;
            const montoConInteres = montoCuota * (1 + interes / 100);
            totalConInteres = montoConInteres * cantCuotas;
            montoPagado = 0;
            saldoPendiente = totalConInteres;
        } else if (formaPago === 'Tarjeta') {
            // Pago único con interés tarjeta
            interes = parseFloat(document.getElementById('interesTarjeta').value) || 0;
            totalConInteres = total * (1 + interes / 100);
            montoPagado = totalConInteres;
            saldoPendiente = 0;
        }

        const data = {
            idCliente: parseInt(document.getElementById('idCliente').value),
            formaPago: noPaga ? 'Cuotas' : formaPago,
            cantCuotas,
            interes,
            fechaPrimeraCuota,
            formaPagoCuotas,
            observacion: document.getElementById('observacion').value,
            montoPagado,
            saldoPendiente,
            totalConInteres,
            items: carrito.map(i => ({
                idProducto: i.idProducto,
                cantidad: i.cantidad,
                precio: i.precio,
                subtotal: i.subtotal,
                tipo: i.tipo,
                descripcion: i.nombre
            }))
        };

        fetch('/Venta/GuardarVenta', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
        })
        .then(r => r.json())
        .then(result => {
            if (result.success) {
                window.location.href = '/Venta/Detalle/' + result.idVenta;
            } else {
                alert('Error: ' + result.error);
            }
        });
    }
</script>