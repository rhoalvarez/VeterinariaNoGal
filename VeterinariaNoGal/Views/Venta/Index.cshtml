@model List<VeterinariaNoGal.Models.Venta>
@{
    ViewData["Title"] = "Ventas";
}
<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 style="font-weight:800; border-left:5px solid #2d5a27; padding-left:12px;">Ventas</h2>
        <div class="d-flex gap-2">
            <a href="/CuentasCorrientes/Index" class="btn btn-secondary">← Servicios</a>
            <a href="/Venta/Crear" class="btn btn-primary">+ Nueva Venta</a>
        </div>
    </div>
    <div style="overflow-x: auto; -webkit-overflow-scrolling: touch;">
        <table class="table table-hover" style="min-width: 650px;">
            <thead class="table-dark">
                <tr>
                    <th>N° Venta</th>
                    <th>Fecha</th>
                    <th>Cliente</th>
                    <th>Total</th>
                    <th>Forma de Pago</th>
                    <th>Estado</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var v in Model)
                {
                    <tr>
                        <td>#@v.IdVentas</td>
                        <td>@v.Fecha.ToString("dd/MM/yyyy")</td>
                        <td>@v.NombreCliente @v.ApellidoCliente</td>
                        <td>$@v.Total.ToString("N2")</td>
                        <td>@v.FormaPago</td>
                        <td>
                            @if (v.EstadoPago == "Pendiente")
                            {
                                <span class="badge bg-warning text-dark">Pendiente</span>
                            }
                            else if (v.EstadoPago == "Pagado")
                            {
                                <span class="badge bg-success">Pagado</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Cancelado</span>
                            }
                        </td>
                        <td class="text-center" style="white-space:nowrap;">
                            <a href="/Venta/Editar/@v.IdVentas" class="btn btn-warning btn-sm" title="Editar">✏️</a>
                            <a href="/Venta/Detalle/@v.IdVentas" class="btn btn-info btn-sm" title="Ver">👁️</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>