@model List<VeterinariaNoGal.Models.Producto>
@{
    ViewData["Title"] = "Productos";
}
<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 style="font-weight:800; border-left:5px solid #2d5a27; padding-left:12px;">Productos</h2>
        <a href="/Producto/Crear" class="btn btn-primary">+ Nuevo Producto</a>
    </div>
    <div class="row g-4">
        @foreach (var p in Model)
        {
            <div class="col-6 col-md-3">
                <div style="background: white; border-radius: 15px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); overflow: hidden; transition: transform 0.2s;" onmouseover="this.style.transform='translateY(-5px)'" onmouseout="this.style.transform='translateY(0)'">
                    <div style="background: #f0f4f0; padding: 10px; text-align: center; height: 140px; display:flex; align-items:center; justify-content:center; overflow:hidden;">
                        <img src="/images/productos/@(string.IsNullOrEmpty(p.Imagen) ? "sin-imagen.png" : p.Imagen)"
                             style="max-height: 130px; max-width: 100%; object-fit: contain; border-radius: 8px;" />
                    </div>
                    <div style="padding: 12px;">
                        <h6 style="color: #2d5a27; font-weight: bold; margin-bottom: 4px; font-size:0.95rem;">@p.Nombre</h6>
                        <p style="color: #888; font-size: 11px; margin-bottom: 4px;">Código: @p.Codigo</p>
                        <p style="color: #666; font-size: 12px; margin-bottom: 8px;">@p.Descripcion</p>
                        <div style="font-size: 1rem; font-weight: bold; color: #2d5a27; margin-bottom:4px;">$@p.PMinorista.ToString("N2")</div>
                        <div style="margin-bottom:6px;">
                            @if (p.Stock <= 5)
                            {
                                <span class="badge bg-warning text-dark" style="font-size:10px;">⚠️ Stock: @p.Stock</span>
                            }
                            else
                            {
                                <span class="badge bg-success" style="font-size:10px;">✅ Stock: @p.Stock</span>
                            }
                        </div>
                        <p style="color: #999; font-size: 11px; margin-bottom:2px;">Mayorista: $@p.PMayorista.ToString("N2")</p>
                        <p style="color: #999; font-size: 11px; margin-bottom:8px;">Proveedor: @p.Proveedor</p>
                        <a href="/Producto/Eliminar/@p.IdProductos"
                           class="btn btn-danger btn-sm w-100"
                           onclick="return confirm('¿Seguro que querés eliminar este producto?')">🗑️ Eliminar</a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>