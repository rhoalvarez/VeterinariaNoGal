@model VeterinariaNoGal.Models.Producto
@{
    ViewData["Title"] = "Nuevo Producto";
}
<div class="container mt-4">
    <h2>Nuevo Producto</h2>
    <form method="post" action="/Producto/Crear" enctype="multipart/form-data">
        <div class="mb-3">
            <label>Código</label>
            <input type="text" name="Codigo" class="form-control" required />
        </div>
        <div class="mb-3">
            <label>Nombre</label>
            <input type="text" name="Nombre" class="form-control" required />
        </div>
        <div class="mb-3">
            <label>Stock</label>
            <input type="number" name="Stock" class="form-control" required />
        </div>
        <div class="mb-3">
            <label>Precio Minorista</label>
            <input type="number" step="0.01" name="PMinorista" class="form-control" required />
        </div>
        <div class="mb-3">
            <label>Precio Mayorista</label>
            <input type="number" step="0.01" name="PMayorista" class="form-control" required />
        </div>
        <div class="mb-3">
            <label>Descripción</label>
            <textarea name="Descripcion" class="form-control" rows="3"></textarea>
        </div>
        <div class="mb-3">
            <label>Proveedor</label>
            <select name="IdProveedor" class="form-control">
                @foreach (var p in ViewBag.Proveedores as List<VeterinariaNoGal.Models.Proveedor>)
                {
                    <option value="@p.IdProveedores">@p.RazonSocial</option>
                }
            </select>
        </div>
        <div class="mb-3">
            <label>Foto del Producto</label>
            <input type="file" name="imagenFile" class="form-control" accept="image/*" />
            <small class="text-muted">Opcional. JPG, PNG o WEBP. Si no subís foto se usará una imagen por defecto.</small>
            <div id="preview" style="margin-top:10px; display:none;">
                <img id="imgPreview" src="" style="max-height:150px; border-radius:10px; border:1px solid #ccc;" />
            </div>
        </div>
        <button type="submit" class="btn btn-success">Guardar</button>
        <a href="/Producto/Index" class="btn btn-secondary">Cancelar</a>
    </form>
</div>

<script>
    document.querySelector('input[name="imagenFile"]').addEventListener('change', function () {
        const file = this.files[0];
        if (file) {
            const reader = new FileReader();
            reader.onload = e => {
                document.getElementById('imgPreview').src = e.target.result;
                document.getElementById('preview').style.display = 'block';
            };
            reader.readAsDataURL(file);
        }
    });
</script>