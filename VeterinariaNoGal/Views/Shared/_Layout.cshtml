       style="position: fixed; bottom: 25px; right: 25px; background: #25D366; color: white; border-radius: 50%; width: 60px; height: 60px; display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 15px rgba(0,0,0,0.3); z-index: 9999; text-decoration: none;"
       title="Contactanos por WhatsApp">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48" width="35px" height="35px">
            <path fill="#fff" d="M4.868,43.303l2.694-9.835C5.9,30.59,5.026,27.324,5.027,23.979C5.032,13.514,13.548,5,24.014,5c5.079,0.002,9.845,1.979,13.43,5.566c3.584,3.588,5.558,8.356,5.556,13.428c-0.004,10.465-8.522,18.98-18.986,18.98c-0.001,0,0,0,0,0h-0.008c-3.177-0.001-6.3-0.798-9.073-2.311L4.868,43.303z" />
            <path fill="#25D366" d="M4.868,43.803c-0.132,0-0.26-0.052-0.355-0.148c-0.125-0.127-0.174-0.312-0.127-0.483l2.639-9.636c-1.636-2.906-2.499-6.206-2.497-9.556C4.532,13.238,13.273,4.5,24.014,4.5c5.21,0.002,10.105,2.031,13.784,5.713c3.679,3.683,5.704,8.577,5.702,13.781c-0.004,10.741-8.746,19.48-19.486,19.48c-3.189-0.001-6.344-0.788-9.144-2.277l-9.875,2.589C4.953,43.798,4.911,43.803,4.868,43.803z" />
            <path fill="#fff" d="M19.005,34.942c0,0,0.185,0.11,0.476,0.24c0,0,3.148,1.322,6.533,1.086c4.44-0.308,7.448-2.564,9.236-5.446c0.892-1.441,1.409-3.102,1.416-4.848C36.67,21.1,33.15,17,29.01,15.5c-1.261-0.462-2.643-0.734-4.064-0.737C18.718,14.751,13.5,19.884,13.5,26.19c0,2.213,0.632,4.29,1.737,6.05L13.5,38l5.541-1.45C19.005,36.55,19.005,34.942,19.005,34.942z" />
