<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - VeterinariaNoGal</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/VeterinariaNoGal.styles.css" asp-append-version="true" />
    <style>
        .alerta-badge {
            position: absolute;
            top: 2px;
            right: -8px;
            background: #e74c3c;
            color: white;
            border-radius: 50%;
            width: 18px;
            height: 18px;
            font-size: 0.7rem;
            font-weight: 700;
            display: flex;
            align-items: center;
            justify-content: center;
            animation: pulse 1.5s infinite;
        }

        @@keyframes pulse {
            0% {
                transform: scale(1);
            }

            50% {
                transform: scale(1.2);
            }

            100% {
                transform: scale(1);
            }
        }

        .nav-bell {
            position: relative;
            display: inline-block;
        }

        .social-btn {
            display: flex;
            align-items: center;
            text-decoration: none;
            border-radius: 30px;
            overflow: hidden;
            max-width: 200px;
            margin: 0 auto 10px auto;
            box-shadow: 0 3px 10px rgba(0,0,0,0.3);
        }

        .social-icon {
            width: 44px;
            height: 44px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            margin: 3px;
        }

        .social-text {
            font-weight: 700;
            font-size: 13px;
            padding: 0 16px;
            height: 50px;
            display: flex;
            align-items: center;
            flex-grow: 1;
            color: white;
        }

        .footer-link {
            color: white !important;
            display: block;
            text-decoration: none;
            font-size: 13px;
            font-weight: 600;
            margin-bottom: 4px;
        }

            .footer-link:hover {
                color: #c8a97e !important;
            }

        .footer-title {
            color: white !important;
            margin-bottom: 8px;
            font-weight: 700;
        }

        @@media (max-width: 768px) {
            .social-btn {
                max-width: 140px;
                border-radius: 20px;
            }

            .social-icon {
                width: 30px;
                height: 30px;
                margin: 2px;
            }

                .social-icon svg {
                    width: 16px;
                    height: 16px;
                }

            .social-text {
                font-size: 11px;
                height: 36px;
                padding: 0 10px;
            }
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark bg-dark border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand d-flex align-items-center" asp-controller="Home" asp-action="Index">
                    <img src="/images/logo.png" style="height: 40px; margin-right: 8px;" />
                    <span style="font-size:0.95rem;">Agroveterinaria El Nogal</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between align-items-center">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Home" asp-action="Index">Inicio</a>
                        </li>
                    </ul>
                    <ul class="navbar-nav align-items-start align-items-sm-center ms-auto">
                        @if (Context.Session.GetString("usuario") != null)
                        {
                            int alertas = VeterinariaNoGal.Models.AlertaHelper.ContarAlertasPendientes();
                            <li class="nav-item me-2">
                                <a href="/Cobros/Alertas" class="nav-bell nav-link" title="Alertas de cuotas">
                                    <span style="font-size:1.3rem;">🔔</span>
                                    @if (alertas > 0)
                                    {
                                        <span class="alerta-badge">@alertas</span>
                                    }
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white" href="/Login/Perfil" style="white-space:nowrap;">
                                    👤 @Context.Session.GetString("usuario")
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="/Login/Logout" style="color: #ffcccc; white-space:nowrap;">
                                    🚪 Cerrar Sesión
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container-body">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer style="background: linear-gradient(135deg, #1e4d18, #3a7a2e); padding: 20px 0; margin-top: 40px;">
        <div style="max-width: 1200px; margin: 0 auto; padding: 0 20px;">
            <div class="row align-items-center">

                <!-- Logo -->
                <div class="col-md-3 text-center mb-3 mb-md-0">
                    <img src="/images/logo.png" style="height: 60px;" />
                    <p style="color: white !important; font-size: 13px; margin-top: 5px; font-weight: 600;">Agroveterinaria El Nogal</p>
                </div>

                <!-- Navegación -->
                <div class="col-md-3 text-center mb-3 mb-md-0">
                    <h6 class="footer-title">Navegación</h6>
                    <a href="/Proveedor/Index" class="footer-link">Proveedores</a>
                    <a href="/Producto/Index" class="footer-link">Productos</a>
                    <a href="/CuentasCorrientes/Index" class="footer-link">Servicios</a>
                    <a href="/Historial/Index" class="footer-link">Historial Clínico</a>
                </div>

                <!-- Contacto -->
                <div class="col-md-3 text-center mb-3 mb-md-0">
                    <h6 class="footer-title">Contacto</h6>

                    <!-- Instagram -->
                    <a href="https://www.instagram.com/agroveterinariaelnogal2026" target="_blank" class="social-btn">
                        <div class="social-icon" style="background: linear-gradient(45deg, #f09433, #e6683c, #dc2743, #cc2366, #bc1888);">
                            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="white">
                                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z" />
                            </svg>
                        </div>
                        <span class="social-text" style="background: linear-gradient(135deg, #1e4d18, #3a7a2e);">Instagram</span>
                    </a>

                    <!-- Facebook -->
                    <a href="https://www.facebook.com/agroveterinarielnogal" target="_blank" class="social-btn">
                        <div class="social-icon" style="background: #1877F2;">
                            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="white">
                                <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
                            </svg>
                        </div>
                        <span class="social-text" style="background: linear-gradient(135deg, #1e4d18, #3a7a2e);">Facebook</span>
                    </a>
                </div>

                <!-- Copyright -->
                <div class="col-md-3 text-center">
                    <p style="color: white !important; font-size: 12px; font-weight: 700; margin: 0;">© 2026 Agroveterinaria El Nogal</p>
                    <p style="color: white !important; font-size: 11px; font-weight: 600; margin: 0;">Todos los derechos reservados</p>
                </div>

            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <!-- Burbuja WhatsApp fija -->
